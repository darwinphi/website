{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "",
  "main": "sass/custom.scss",
  "scripts": {
    "css-watch": "sass --watch sass:css --style=compressed --silence-deprecation=import,global-builtin,color-functions,if-function",
    "css-build": "sass sass/custom.scss:css/main.min.css --style=compressed --silence-deprecation=import,global-builtin,color-functions,if-function && sass sass/custom.scss:css/main.css --style=expanded --silence-deprecation=import,global-builtin,color-functions,if-function",
    "start": "npm run css-watch"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "bulma": "^0.9.3",
    "sass": "^1.77.0"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "bulma-modal-fx": "^1.1.1"
  },
  "browserslist": [
    "> 1%",
    "last 4 versions",
    "not dead"
  ]
}
